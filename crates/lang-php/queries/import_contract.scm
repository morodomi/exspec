; Laravel Validation: use Illuminate\Validation
(namespace_use_declaration
  (namespace_use_clause
    (qualified_name) @_name
    (#match? @_name "Illuminate\\\\(Foundation\\\\Http\\\\FormRequest|Validation)"))) @contract_import

; Symfony Validator: use Symfony\Component\Validator
(namespace_use_declaration
  (namespace_use_clause
    (qualified_name) @_name
    (#match? @_name "Symfony\\\\Component\\\\Validator"))) @contract_import
